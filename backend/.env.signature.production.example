# ===========================================
# DIFFsense Signature - Production Environment
# ===========================================

# --- Runtime ---
NODE_ENV=production
AUTH_BYPASS=false
PORT=3001

# --- Signature App URLs ---
APP_URL=https://diffsense.spacegleam.co.jp
FRONTEND_URL=https://diffsense.spacegleam.co.jp
ALLOWED_ORIGINS=https://diffsense.spacegleam.co.jp

# --- Signature Security ---
JWT_SECRET=SET_A_LONG_RANDOM_SECRET

# --- Signature Mail ---
RESEND_API_KEY=SET_RESEND_API_KEY
MAIL_FROM=noreply@send.spacegleam.co.jp
MAIL_REPLY_TO=contact@spacegleam.co.jp

# --- Firebase Admin SDK ---
FIREBASE_PROJECT_ID=SET_PROJECT_ID
FIREBASE_CLIENT_EMAIL=SET_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSET_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=SET_STORAGE_BUCKET

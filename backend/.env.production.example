# ===========================================
# DIFFsense Backend - Production Environment
# ===========================================

NODE_ENV=production
AUTH_BYPASS=false
PORT=3001

# --- App URLs ---
APP_URL=https://diffsense.spacegleam.co.jp
FRONTEND_URL=https://diffsense.spacegleam.co.jp
DASHBOARD_URL=https://diffsense.spacegleam.co.jp/dashboard.html#sign
ALLOWED_ORIGINS=https://diffsense.spacegleam.co.jp

# --- Signature / Mail ---
JWT_SECRET=SET_A_LONG_RANDOM_SECRET
RESEND_API_KEY=SET_RESEND_API_KEY
MAIL_FROM=noreply@send.spacegleam.co.jp
MAIL_REPLY_TO=contact@spacegleam.co.jp

# --- Firebase Admin SDK ---
FIREBASE_PROJECT_ID=SET_PROJECT_ID
FIREBASE_CLIENT_EMAIL=SET_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSET_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=SET_STORAGE_BUCKET

# --- AI ---
GEMINI_API_KEY=SET_GEMINI_API_KEY

# --- Firma ---
FIRMA_API_KEY=SET_FIRMA_API_KEY
FIRMA_BASE_URL=https://api.firma.dev/functions/v1/signing-request-api
FIRMA_WEBHOOK_SECRET=SET_FIRMA_WEBHOOK_SECRET

# --- PayPal ---
PAYPAL_CLIENT_ID=SET_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=SET_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=live
PAYPAL_PLAN_STARTER=SET_PAYPAL_PLAN_STARTER
PAYPAL_PLAN_BUSINESS=SET_PAYPAL_PLAN_BUSINESS
PAYPAL_PLAN_PRO=SET_PAYPAL_PLAN_PRO
PAYPAL_PLAN_STARTER_ANNUAL=SET_PAYPAL_PLAN_STARTER_ANNUAL
PAYPAL_PLAN_BUSINESS_ANNUAL=SET_PAYPAL_PLAN_BUSINESS_ANNUAL
PAYPAL_PLAN_PRO_ANNUAL=SET_PAYPAL_PLAN_PRO_ANNUAL
PAYPAL_WEBHOOK_ID=SET_PAYPAL_WEBHOOK_ID

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=SET_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=SET_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=SET_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=SET_STRIPE_PRICE_STARTER
STRIPE_PRICE_BUSINESS=SET_STRIPE_PRICE_BUSINESS
STRIPE_PRICE_PRO=SET_STRIPE_PRICE_PRO
STRIPE_PRICE_STARTER_ANNUAL=SET_STRIPE_PRICE_STARTER_ANNUAL
STRIPE_PRICE_BUSINESS_ANNUAL=SET_STRIPE_PRICE_BUSINESS_ANNUAL
STRIPE_PRICE_PRO_ANNUAL=SET_STRIPE_PRICE_PRO_ANNUAL

# --- Operational Settings ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE_MB=50
TRIAL_REMINDER_ENABLED=true
TRIAL_REMINDER_CRON="0 10 * * *"
TRIAL_REMINDER_TIMEZONE="Asia/Tokyo"
TRIAL_REMINDER_DAYS_BEFORE=3

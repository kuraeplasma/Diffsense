{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "functions": [
        {
            "source": "backend",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log"
            ],
            "predeploy": [
                "npm --prefix \"$RESOURCE_DIR\" install"
            ]
        }
    ],
    "hosting": {
        "public": ".",
        "redirects": [
            {
                "source": "/news",
                "destination": "/news.html",
                "type": 301
            },
            {
                "source": "/news/",
                "destination": "/news.html",
                "type": 301
            }
        ],
        "rewrites": [
            {
                "source": "/sign",
                "destination": "/signing.html"
            },
            {
                "source": "/sign/**",
                "destination": "/signing.html"
            }
        ],
        "rewrites": [
            {
                "source": "/sign",
                "destination": "/signing.html"
            },
            {
                "source": "/sign/**",
                "destination": "/signing.html"
            }
        ],
        "ignore": [
            "firebase.json",
            "**/.*",
            ".git/**",
            ".claude/**",
            ".agent/**",
            ".agents/**",
            ".firebase/**",
            ".codex*/**",
            "codex_*/**",
            "_backup_*/**",
            "_deploy_*/**",
            "_restore_*/**",
            ".deploy_*/**",
            ".tmp_*/**",
            "backups/**",
            "docs/**",
            "logs/**",
            "note-drafts/**",
            "**/node_modules/**",
            "backend/**",
            "netlify/**"
        ]
    }
}
